# ──────────────────────────────────────────────
# GGID Admin Console — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and adjust as needed:
#   cp .env.example .env.local

# ── API Connection ────────────────────────────

# API Gateway URL (the entry point for all backend services)
# Default: http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# Default tenant ID for Console requests
# All API calls include this in the X-Tenant-ID header
# Default: 00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# ── Server-side only (not exposed to browser) ──

# Gateway URL for Next.js rewrites (server-side proxy)
# Used in next.config.ts for /api/* and /oauth/* proxy rules
# Default: http://localhost:8080
# GATEWAY_URL=http://localhost:8080
