{
  "annotations": { "list": [] },
  "title": "GGID Security Overview",
  "uid": "ggid-security",
  "version": 1,
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "15s",
  "tags": ["ggid", "security"],
  "panels": [
    {
      "id": 1,
      "title": "Auth Failure Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ggid_auth_failures_total[5m])) / sum(rate(ggid_auth_attempts_total[5m])) * 100", "legendFormat": "failure %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":15}] } } }
    },
    {
      "id": 2,
      "title": "429 Rate Limited Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ggid_http_requests_total{status=\"429\"}[5m]))", "legendFormat": "429 req/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "title": "401/403 Rejected Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ggid_http_requests_total{status=~\"401|403\"}[5m]))", "legendFormat": "rejected req/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "title": "Risk Evaluations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ggid_risk_evaluations_total[5m]))", "legendFormat": "eval/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "title": "Auth Failures Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum by (reason) (rate(ggid_auth_failures_total[5m]))", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "title": "Risk Evaluations by Source",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "sum by (source, action) (rate(ggid_risk_evaluations_total[5m]))", "legendFormat": "{{source}}: {{action}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 7,
      "title": "Status Code Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum by (status) (rate(ggid_http_requests_total[1m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "title": "OAuth Token Endpoint Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "sum(rate(ggid_http_requests_total{path=\"/oauth/token\"}[1m]))", "legendFormat": "token req/s" },
        { "expr": "sum(rate(ggid_http_requests_total{path=\"/oauth/token\",status=\"429\"}[1m]))", "legendFormat": "rate limited" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9,
      "title": "Login Attempts (success vs failure)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        { "expr": "sum(rate(ggid_auth_attempts_total{result=\"success\"}[5m]))", "legendFormat": "successful logins" },
        { "expr": "sum(rate(ggid_auth_attempts_total{result=\"failure\"}[5m]))", "legendFormat": "failed logins" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
