# GGID IAM Platform — Production Environment Configuration
# Copy to .env and customize before running: docker compose -f docker-compose.prod.yaml --env-file .env up -d

# === PostgreSQL ===
POSTGRES_USER=ggid
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=ggid
POSTGRES_PORT=5432

# === Redis ===
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# === LDAP ===
LDAP_ADMIN_PASSWORD=change-me-to-a-strong-ldap-password
LDAP_ORGANISATION="GGID Corp"
LDAP_DOMAIN=corp.local

# === JWT Keys ===
# Paths inside the ggid-configs volume
JWT_PRIVATE_KEY_PATH=/configs/rsa_private.pem
JWT_PUBLIC_KEY_PATH=/configs/rsa_public.pem

# === Gateway ===
GATEWAY_PORT=8080

# === Console ===
CONSOLE_PORT=3000
NEXTAUTH_URL=https://iam.example.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# === TLS (optional, for nginx proxy) ===
TLS_CERT_FILE=/certs/fullchain.pem
TLS_KEY_FILE=/certs/privkey.pem
TLS_DOMAIN=iam.example.com

# === NATS ===
NATS_URL=nats://nats:4222

# === Default Tenant ===
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
