    {
      "name": "OAuth / OIDC",
      "item": [
        {
          "name": "JWKS Endpoint",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/.well-known/jwks.json",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "OIDC Discovery",
          "request": {
