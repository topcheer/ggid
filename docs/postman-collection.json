{
  "info": {
    "name": "GGID IAM Platform API",
    "_postman_id": "ggid-iam-v1",
    "description": "Complete API collection for the GGID Identity & Access Management Platform.\n\n## Setup\n1. Set the `base_url` variable to your Gateway URL (default: http://localhost:8080)\n2. Set the `tenant_id` variable (default: 00000000-0000-0000-0000-000000000001)\n3. Run the \"Login\" request first to get a JWT token\n4. The token is auto-saved to the `access_token` variable\n\n## Authentication\nAll requests use Bearer JWT authentication (auto-injected via collection variable).\n\n## Multi-Tenancy\nEvery request includes the X-Tenant-ID header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variables": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "tenant_id", "value": "00000000-0000-0000-0000-000000000001", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" },
    { "key": "role_id", "value": "", "type": "string" },
    { "key": "org_id", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.add({key: 'X-Tenant-ID', value: pm.variables.get('tenant_id')});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz",
            "auth": { "type": "noauth" }
          },
          "response": []
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz/ready",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["if (pm.response.code === 201) {", "  var body = pm.response.json();", "  if (body.user_id) pm.variables.set('user_id', body.user_id);", "}"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"email\": \"postman@example.com\",\n  \"password\": \"SecurePass@123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body.access_token) pm.variables.set('access_token', body.access_token);",
                  "  if (body.refresh_token) pm.variables.set('refresh_token', body.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"password\": \"SecurePass@123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"access_token\": \"{{access_token}}\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/password/change",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"SecurePass@123\",\n  \"new_password\": \"NewSecurePass@456\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/password/forgot",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/password/reset",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset_token_from_email\",\n  \"password\": \"NewSecurePass@456\"\n}"
            }
          }
        },
        {
          "name": "MFA Setup (TOTP)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/mfa/setup"
          }
        },
        {
          "name": "MFA Verify",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/mfa/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Email Verify",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/email/verify",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"verification_token_from_email\"\n}"
            }
          }
        },
        {
          "name": "Email Resend Verification",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/email/resend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman@example.com\"\n}"
            }
          }
        },
        {
          "name": "Magic Link Send",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/magic-link",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman@example.com\"\n}"
            }
          }
        },
        {
          "name": "Magic Link Verify",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/magic-link/verify",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"magic_link_token\"\n}"
            }
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/sessions"
          }
        },
        {
          "name": "Logout All Devices",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout-all"
          }
        },
        {
          "name": "Password Policy",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/password/policy"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/users?page_size=20", "host": ["{{base_url}}"], "path": ["/api/v1/users"], "query": [{ "key": "page_size", "value": "20" }] }
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["if (pm.response.code === 201) {", "  var body = pm.response.json();", "  if (body.id) pm.variables.set('user_id', body.id);", "}"] }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"new_user\",\n  \"email\": \"new@example.com\",\n  \"password\": \"SecurePass@123\",\n  \"display_name\": \"New User\",\n  \"phone\": \"+1234567890\"\n}"
            }
          }
        },
