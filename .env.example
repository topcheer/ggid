# GGID Environment Configuration
# Copy to .env and customize for your deployment

# === Database ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=ggid
DB_PASSWORD=ggid
DB_NAME=ggid
DATABASE_URL=postgres://ggid:ggid@localhost:5432/ggid?sslmode=disable

# === Redis ===
REDIS_URL=redis://localhost:6379

# === NATS ===
NATS_URL=nats://localhost:4222

# === Gateway ===
GATEWAY_ADDR=:8080
GATEWAY_URL=http://localhost:8080

# === Identity Service ===
IDENTITY_HTTP_ADDR=:8081
IDENTITY_GRPC_ADDR=:50051
IDENTITY_SERVICE_URL=http://localhost:8081

# === Auth Service ===
AUTH_HTTP_ADDR=:9001
AUTH_GRPC_ADDR=:50052
AUTH_SERVICE_URL=http://localhost:9001

# === OAuth Service ===
OAUTH_HTTP_ADDR=:9005
OAUTH_GRPC_ADDR=:50055
OAUTH_SERVICE_URL=http://localhost:9005

# === Policy Service ===
POLICY_HTTP_ADDR=:8070
POLICY_GRPC_ADDR=:9070
POLICY_SERVICE_URL=http://localhost:8070

# === Org Service ===
ORG_HTTP_ADDR=:8071
ORG_GRPC_ADDR=:9071
ORG_SERVICE_URL=http://localhost:8071

# === Audit Service ===
AUDIT_HTTP_ADDR=:8072
AUDIT_GRPC_ADDR=:9072
AUDIT_SERVICE_URL=http://localhost:8072

# === Console (Next.js) ===
CONSOLE_PORT=3000
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# === Security ===
JWT_SIGNING_KEY_PATH=/app/configs/rsa_private.pem
OAUTH_PRIVATE_KEY_PATH=/app/configs/rsa_private.pem
INTERNAL_AUTH_SECRET=change-me-in-production

# === Optional: External Services ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# VAULT_ADDR=
# VAULT_TOKEN=
