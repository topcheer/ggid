{
    "name": "ggid/sdk",
    "description": "GGID IAM Platform PHP SDK — JWT verification, OAuth/OIDC, RBAC, ABAC, and framework middleware",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["iam", "sso", "oauth", "oidc", "rbac", "abac", "jwt", "middleware"],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ggid\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ggid\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
